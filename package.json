{
  "name": "docxinweb",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source high-fidelity Word/.docx viewer and editor for the web",
  "license": "PolyForm-Noncommercial-1.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @docxinweb/core -w @docxinweb/react",
    "test": "npm run test -w @docxinweb/core",
    "dev": "npm run dev -w demo",
    "test:e2e": "playwright test",
    "parity": "node scripts/parity-compare.mjs",
    "report:snapshot": "cp parity/out/report.html apps/demo/public/report.html"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
